# Copy to .env and fill in values
# REQUIRED
JWT_SECRET=change-me-to-a-long-random-string
WEBHOOK_SECRET=change-me-to-another-long-random-string

# Platform Admin (first-run seed — change before deploying!)
# Username is the email/username used to log in. Password must be >= 8 characters.
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin1234

# Azure OpenAI (REQUIRED for AI schema mapping)

# ─── AI Provider (mapping-engine) ─────────────────────────────────────────────
# Set AI_PROVIDER to one of: azure | openai | openai-compatible
AI_PROVIDER=azure

# Azure OpenAI (used when AI_PROVIDER=azure)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini        # your deployment name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Plain OpenAI (used when AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible endpoint — Groq, Ollama, Together AI, etc. (AI_PROVIDER=openai-compatible)
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=llama-3.1-8b-instant
# OPENAI_BASE_URL=https://api.groq.com/openai/v1


# OPTIONAL (defaults shown)
CORS_ORIGIN=*
LOG_LEVEL=info
RATE_LIMIT_MAX=1000
