# ─────────────────────────────────────────────────────────────────────────────
# Fly.io deployment environment — copy to .env.fly and fill in values
# Used by:  infra/fly/setup.sh   (one-time provisioning)
#           infra/fly/deploy.sh  (manual deploy / re-deploy)
# Never commit .env.fly — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Fly.io auth & config ──────────────────────────────────────────────────────
FLY_API_TOKEN=             # flyctl auth token
FLY_ORG=personal           # your Fly org slug (run: flyctl orgs list)
FLY_REGION=lhr             # lhr=London  iad=US-East  sin=Singapore  nrt=Tokyo

# ── Application secrets (shared across all backend services) ──────────────────
JWT_SECRET=                # long random string  (openssl rand -hex 32)
WEBHOOK_SECRET=            # long random string  (openssl rand -hex 32)
# DATABASE_URL is auto-provisioned by setup.sh via `flyctl postgres attach`.
# Leave blank on first run. After provisioning it will be written back here.
# To override (e.g. external DB): postgres://user:pass@host:5432/dbname
DATABASE_URL=

# ── AI provider (mapping-engine & agent-orchestrator) ─────────────────────────
# Set AI_PROVIDER to one of: azure | openai | openai-compatible
AI_PROVIDER=azure

# Azure OpenAI (AI_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Plain OpenAI (AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible — Groq, Ollama, Together AI, etc. (AI_PROVIDER=openai-compatible)
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=llama-3.1-8b-instant
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── Partner portal ────────────────────────────────────────────────────────────
# Public URL of the gateway (used as build-time arg for Next.js)
GATEWAY_URL=https://bx-gateway.fly.dev
